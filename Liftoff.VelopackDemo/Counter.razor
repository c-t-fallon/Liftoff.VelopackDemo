@inject IJSRuntime JS

<SfGrid DataSource="@Orders" />

@code {
    public List<Order> Orders { get; set; }

    protected override void OnInitialized()
    {
        Orders = Enumerable.Range(1, 5).Select(x => new Order()
        {
            OrderID = 0 + x,
            CustomerID = (new string[] { "ALFKI", "ANANTR", "ANTON", "BLONP", "BOLID" })[new Random().Next(5)],
        }).ToList();


        if (string.IsNullOrEmpty(App.SyncfusionLicenseKeyEnvironmentVariable))
        {
            JS.InvokeVoidAsync("console.log", "env var is empty");
        }
        else
        {
            JS.InvokeVoidAsync("console.log", "env var is not empty");
        }

        if (string.IsNullOrEmpty(App.SyncfusionLicenseKeyUserSecretsKey))
        {
            JS.InvokeVoidAsync("console.log", "user secret is empty");
        }
        else
        {
            JS.InvokeVoidAsync("console.log", "user secret is not empty");
        }
    }

    public class Order
    {
        public int? OrderID { get; set; }
        public string CustomerID { get; set; }
    }
}