@page "/viewsvg"

<DrawingViewer Width="100%" Height="calc(100vh - 6rem)" Lines="_lines" Texts="_texts" />

@code {
    private List<DrawingLine> _lines =
    [
        new DrawingLine(50,  50,  750, 50),
        new DrawingLine(750, 50,  750, 550),
        new DrawingLine(750, 550, 50,  550),
        new DrawingLine(50,  550, 50,  50),
        new DrawingLine(100, 150, 400, 400),
        new DrawingLine(400, 150, 100, 400),
    ];

    private List<DrawingText> _texts =
    [
        new DrawingText(100, 100, "Drawing Viewer"),
        new DrawingText(100, 480, "Lines: 6  |  Texts: 2"),
    ];
}
