@inherits LayoutComponentBase

@inject IUpdateService _update
@inject TelemetryClient _telemetry;

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @if (_update.IsUpdateAvailable())
            {
                <SfDropDownButton IconCss="bi bi-arrow-up-circle" Content="Update" CssClass="e-info">
                    <DropDownButtonEvents ItemSelected="ItemSelected" />
                    <DropDownMenuItems>
                        <DropDownMenuItem @ref="updateAndRestartItem" IconCss="bi bi-arrow-clockwise" Text="Update and Restart"></DropDownMenuItem>
                        <DropDownMenuItem @ref="updateAndExitItem" IconCss="bi bi-box-arrow-right" Text="Update and Exit"></DropDownMenuItem>
                        <DropDownMenuItem IconCss="bi bi-info-circle" Text="Details"></DropDownMenuItem>
                    </DropDownMenuItems>
                </SfDropDownButton>                
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    DropDownMenuItem updateAndRestartItem;
    DropDownMenuItem updateAndExitItem;

    protected override Task OnInitializedAsync()
    {
        _update.DownloadCompleted += (sender, args) =>
        {
            _telemetry.TrackEvent("UpdateDownloadCompleted");
            StateHasChanged();
        };

        return base.OnInitializedAsync();
    }

    private void ItemSelected(MenuEventArgs args)
    {
        if (args.Item == updateAndRestartItem)
        {
            UpdateAndRestart();
        }
        else if (args.Item == updateAndExitItem)
        {
            UpdateAndExit();
        }
    }

    void UpdateAndRestart()
    {
        _update.UpdateAndRestart();
        _telemetry.TrackEvent("UpdateAndRestartClicked");
    }

    void UpdateAndExit()
    {
        _update.UpdateAndExit();
        _telemetry.TrackEvent("UpdateAndExitClicked");
    }
}